<div class="projects-page">
  <h1>Projekte</h1>
  <div class="projects-grid">
    <%= for p <- @projects do %>
      <div class="project-card">
        <h3><%= p.name %></h3>
        <p><%= p.description %></p>
        <span class="tag">Status: <%= p.status %></span>
        <span class="muted">von <%= p.owner_username %></span>
      </div>
    <% end %>
  </div>
</div>
