<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ideen</title>
  
  <link rel="stylesheet" href="/css/ideas.css">


  <%- include('../partials/head') %>
  

  
  <script>
    window.ideaLiveVersion = <%= Number(liveVersion || 0) %>;
  </script>
  <script src="/js/dist/ideas/live.min.js"></script>
  <script src="/js/dist/ideas/shared.min.js"></script>
  <script src="/js/dist/ideas/card.min.js"></script>
  <script src="/js/dist/ideas/nav.min.js"></script>
  <script src="/js/dist/ideas/interactions.min.js"></script>
  <script src="/js/dist/ideas/comments.min.js"></script>
  
</head>
<body data-live-version="<%= Number(liveVersion || 0) %>">

<%- include('../partials/header') %>

<main class="ideas-page">
  
  <section class="ideas-header">
    <div class="hero-box ideas-hero-container">
      <h1>Ideenboard</h1>
      <p class="subtitle">Teilen Sie Ihre Visionen und gestalten Sie die Zukunft mit</p>
      <button class="btn accent" id="openCreateModal">
        <span class="btn-icon">+</span> Neue Idee
      </button>
    </div>
  </section>
  
  <!-- Filters (HTMX Powered) -->
  <section class="ideas-filters hero-overlap-next" aria-label="Filter und Suche">
    <form id="filterForm" class="filter-form" onsubmit="event.preventDefault(); return false;">
     
    <div class="filter-row search-row">

      <div class="search-field">

        <input id="q" name="q" type="text" value="<%= q || '' %>" 
       placeholder="Suche nach Titel, Autor oder Beschreibung" class="input"
       aria-label="Suche"
       hx-get="/ideas"
      hx-trigger="keyup changed delay:1000ms, search" 
       hx-target="#ideas-content"
       hx-swap="outerHTML"
       hx-push-url="true"
       hx-indicator="#loading-indicator"
       hx-vals='{"page":1}'
       hx-include="#filterForm">
     <span class="search-glass">
          <svg width="23" height="23" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M28.7,27.29l-9.76-9.56A9,9,0,1,0,12,21a8.92,8.92,0,0,0,5.49-1.89l9.81,9.6a1,1,0,0,0,1.41,0A1,1,0,0,0,28.7,27.29ZM5,12a7,7,0,1,1,7,7A7,7,0,0,1,5,12Z" fill="currentColor"/>
          </svg>
        </span>
        <button type="button" id="q-clear" class="clear-search" aria-label="Suche löschen" title="Suche löschen"
        hx-on:click="const q = document.getElementById('q'); q.value=''; htmx.trigger(q, 'search'); q.focus();">
  ×
</button>


      </div>
    </div>
    
     <div class="filter-row options-row">


      <span class="select-wrap">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M12,25l6.67,6.67a1,1,0,0,0,.7.29.91.91,0,0,0,.39-.08,1,1,0,0,0,.61-.92V13.08L31.71,1.71A1,1,0,0,0,31.92.62,1,1,0,0,0,31,0H1A1,1,0,0,0,.08.62,1,1,0,0,0,.29,1.71L11.67,13.08V24.33A1,1,0,0,0,12,25ZM3.41,2H28.59l-10,10a1,1,0,0,0-.3.71V28.59l-4.66-4.67V12.67a1,1,0,0,0-.3-.71Z"/>
        </svg>
        <select id="category_id" name="category_id" class="input"
                hx-get="/ideas"
                hx-target="#ideas-content"
                hx-swap="outerHTML"
                hx-push-url="true"
                hx-indicator="#loading-indicator"
                hx-vals='{"page":1}'
                hx-include="#filterForm">
          <option value="">Alle Kategorien</option>
          <% (categories || []).forEach(cat => { %>
            <option value="<%= cat.category_id %>" <%= String(category_id) === String(cat.category_id) ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </span>

      <span class="select-wrap">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <line x1="22" y1="26.1" x2="22" y2="5" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <polyline points="17.7,21.8 22,26.1 26.3,21.8" stroke="currentColor" stroke-width="2" stroke-miterlimit="10" fill="none"/>
          <line x1="4" y1="6" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <line x1="4" y1="10" x2="14" y2="10" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <line x1="4" y1="14" x2="12" y2="14" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <line x1="4" y1="18" x2="10" y2="18" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <line x1="4" y1="22" x2="8" y2="22" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
          <line x1="4" y1="26" x2="6" y2="26" stroke="currentColor" stroke-width="2" stroke-miterlimit="10"/>
        </svg>
        <select id="sort" name="sort" class="input"
                hx-get="/ideas"
                hx-target="#ideas-content"
                hx-swap="outerHTML"
                hx-push-url="true"
                hx-indicator="#loading-indicator"
                hx-vals='{"page":1}'
                hx-include="#filterForm">
          <option value="latest"   <%= (sort || '').replace('all_', '') === 'latest' || !sort ? 'selected' : '' %>>Neueste zuerst</option>
          <option value="oldest"   <%= (sort || '').replace('all_', '') === 'oldest' ? 'selected' : '' %>>Älteste zuerst</option>
          <option value="likes"    <%= (sort || '').replace('all_', '') === 'likes' ? 'selected' : '' %>>Meiste Likes</option>
          <option value="comments" <%= (sort || '').replace('all_', '') === 'comments' ? 'selected' : '' %>>Meiste Kommentare</option>
          <option value="dislikes" <%= (sort || '').replace('all_', '') === 'dislikes' ? 'selected' : '' %>>Meiste Dislikes</option>
          <option value="score" <%= (sort || '').replace('all_', '') === 'score' ? 'selected' : '' %>>Nur Score</option>
        </select>
      </span>

      <label class="checkbox-filter toggle-filter">
        <input type="checkbox" id="owned_only" name="owned_only" value="true"
          <%= (typeof owned_only !== 'undefined' && owned_only === 'true') ? 'checked' : '' %>
          hx-get="/ideas"
          hx-target="#ideas-content"
          hx-swap="outerHTML"
          hx-push-url="true"
          hx-indicator="#loading-indicator"
          hx-vals='{"page":1}'
          hx-include="#filterForm"
          onchange="this.parentElement.querySelector('.toggle-label').textContent = this.checked ? 'Meine Ideen' : 'Alle Ideen'">
        <span class="toggle-icons">
          <span class="icon-group" aria-hidden="true">
            <svg width="20" height="20" viewBox="924 565.952 200 200" fill="currentColor">
              <g>
                <path d="M984.585,626.893c0,14-9.609,25.348-21.461,25.348s-21.459-11.348-21.459-25.348c0-13.999,9.607-25.345,21.459-25.345S984.585,612.895,984.585,626.893z"/>
                <path d="M987.586,671.591c1.549-0.945,3.265-1.56,5.041-1.854c-3.606-5.088-6.161-10.546-7.637-17.078c-0.404-2.387-3.672-2.667-6.102-0.687c-4.545,3.706-9.849,6.186-15.764,6.186c-6.03,0-11.577-2.399-16.025-6.414c-1.419-1.283-3.51-1.476-5.142-0.479c-8.444,5.157-14.835,13.344-17.623,23.064c-0.748,2.607-0.223,5.421,1.411,7.59c1.637,2.166,4.192,3.443,6.906,3.443h38.669C975.947,680.023,981.41,675.362,987.586,671.591z"/>
                <path d="M1063.414,626.893c0,14,9.61,25.348,21.462,25.348s21.46-11.348,21.46-25.348c0-13.999-9.608-25.345-21.46-25.345S1063.414,612.895,1063.414,626.893z"/>
                <path d="M1060.413,671.591c-1.549-0.945-3.264-1.56-5.04-1.854c3.605-5.088,6.16-10.546,7.637-17.078c0.404-2.387,3.674-2.667,6.103-0.687c4.545,3.706,9.849,6.186,15.764,6.186c6.03,0,11.576-2.399,16.024-6.414c1.42-1.283,3.51-1.476,5.143-0.479c8.443,5.157,14.834,13.344,17.623,23.064c0.748,2.608,0.222,5.421-1.412,7.59c-1.635,2.166-4.192,3.443-6.906,3.443h-38.668C1072.052,680.023,1066.59,675.362,1060.413,671.591z"/>
                <path d="M1082.474,713.402c-4.198-14.654-13.72-27.044-26.327-34.991c-2.487-1.567-5.715-1.313-7.921,0.631c-6.765,5.958-15.136,9.506-24.226,9.506c-9.268,0-17.791-3.686-24.626-9.856c-2.181-1.97-5.393-2.267-7.901-0.734c-12.977,7.925-22.8,20.505-27.082,35.445c-1.151,4.008-0.344,8.329,2.166,11.663c2.516,3.329,6.443,5.29,10.615,5.29h92.521c4.173,0,8.103-1.954,10.618-5.29C1082.822,721.731,1083.625,717.414,1082.474,713.402z"/>
                <path d="M1056.98,640.499c0,21.512-14.767,38.955-32.98,38.955s-32.979-17.442-32.979-38.955c0-21.515,14.765-38.951,32.979-38.951S1056.98,618.984,1056.98,640.499z"/>
              </g>
            </svg>
          </span>
          <span class="icon-person" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor">
              <path d="M16 15.503A5.041 5.041 0 1 0 16 5.42a5.041 5.041 0 0 0 0 10.083zm0 2.215c-6.703 0-11 3.699-11 5.5v3.363h22v-3.363c0-2.178-4.068-5.5-11-5.5z"/>
            </svg>
          </span>
        </span>
        <span class="toggle-label"><%= (typeof owned_only !== 'undefined' && owned_only === 'true') ? 'Meine Ideen' : 'Alle Ideen' %></span>
      </label>

      <label class="checkbox-filter scope-filter">
        <input type="checkbox" id="search_scope" name="search_scope" value="desc"
          <%= (search_scope === 'desc' || search_scope === 'description') ? 'checked' : '' %>
          hx-get="/ideas"
          hx-target="#ideas-content"
          hx-swap="outerHTML"
          hx-push-url="true"
          hx-indicator="#loading-indicator"
          hx-vals='{"page":1}'
          hx-include="#filterForm">
        <svg width="20" height="20" viewBox="0 0 415.881 415.881" fill="currentColor" aria-hidden="true">
          <path d="M179.641,189.565c2.455,0,4.869,0.193,7.223,0.561l36.999-36.998c-13.193-7.048-28.249-11.051-44.221-11.051c-51.92,0-94.162,42.241-94.162,94.162c0,51.921,42.242,94.162,94.162,94.162s94.161-42.241,94.161-94.162c0-15.973-4.002-31.027-11.051-44.22l-36.997,36.999c0.367,2.354,0.56,4.766,0.56,7.222c0,25.736-20.937,46.674-46.672,46.674c-25.736,0-46.674-20.938-46.674-46.674S153.905,189.565,179.641,189.565z"/>
          <path d="M290.454,164.316c13.488,20.712,21.338,45.417,21.338,71.922c0,72.87-59.281,132.153-132.15,132.153c-72.869,0-132.153-59.283-132.153-132.152s59.283-132.153,132.152-132.153c26.508,0,51.211,7.851,71.924,21.34l34.104-34.104c-29.738-21.817-66.402-34.724-106.027-34.724c-99.055,0-179.641,80.587-179.641,179.641c0,99.054,80.586,179.642,179.641,179.642c99.054,0,179.638-80.588,179.638-179.642c0-39.626-12.904-76.29-34.721-106.026L290.454,164.316z"/>
          <path d="M415.415,56.64c-1.119-3.539-4.119-6.157-7.775-6.793l-35.449-6.157l-6.156-35.45c-0.637-3.656-3.256-6.655-6.793-7.774c-3.537-1.122-7.402-0.178-10.027,2.447l-27.412,27.411c-1.863,1.864-2.91,4.393-2.912,7.029l0.002,40.896l-148.1,148.096c-5.176,5.177-5.176,13.566,0,18.743c5.178,5.175,13.568,5.177,18.744,0L337.632,96.991h40.896c2.635,0,5.164-1.047,7.027-2.911l27.412-27.413C415.593,64.044,416.536,60.177,415.415,56.64z"/>
        </svg> Nur Beschreibung
      </label>



    
      <input id="tags" name="tags" type="text" value="<%= tags || '' %>" 
             placeholder="Tags (Komma-getrennt)" class="input"
             hx-get="/ideas"
             hx-trigger="keyup changed delay:1000ms"
             hx-target="#ideas-content"
             hx-swap="outerHTML"
             hx-push-url="true"
             hx-indicator="#loading-indicator"
             hx-vals='{"page":1}'
             hx-include="#filterForm">
    </div>
    
    <span id="loading-indicator" class="htmx-indicator">Suchen...</span>
    
  </form>
</section>

  <!-- Ideas grid -->

  <%- include('_content') %>

  <dialog id="createIdeaModal" aria-modal="true" aria-labelledby="createIdeaTitle">
    <form method="dialog" class="modal-close">
      <button class="btn outline" value="cancel">Schließen</button>
    </form>
    
    <form id="createIdeaForm" action="/ideas" method="POST" enctype="multipart/form-data">
      <h3 id="createIdeaTitle">Neue Idee</h3>
      
      <label class="form-label" for="new-title">Titel</label>
      <input id="new-title" class="input" type="text" name="title" placeholder="Kurzer, prägnanter Titel" required maxlength="50">
      
      <label class="form-label" for="new-desc">Beschreibung</label>
      <textarea id="new-desc" class="input" name="description" rows="4" placeholder="Beschreibe die Idee, Problem und Lösung" required></textarea>
      
      <label class="form-label" for="new-cat">Kategorie</label>
      <select id="new-cat" class="input" name="category_id" required>
        <% (categories || []).forEach(cat => { %>
          <option value="<%= cat.category_id %>"><%= cat.name %></option>
        <% }) %>
      </select>
      
      <label class="form-label" for="new-tags">Tags</label>
      <input id="new-tags" class="input" type="text" name="tags" placeholder="z. B. ux, performance, kosten">
      
      <label class="form-label" for="new-file">Datei (optional)</label>
      <input id="new-file" class="input" type="file" name="file" accept="*/*">
      
      <div class="dialog-actions" style="display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.6rem;">
        <button class="btn outline" type="reset">Zurücksetzen</button>
        <button class="btn" type="submit">Erstellen</button>
      </div>
    </form>
  </dialog>

  <dialog id="idea-edit-modal">
    <button class="close-btn" onclick="closeIdeaEditModal()">×</button>
    <div id="idea-edit-modal-content"></div>
  </dialog>

</main>

 <%- include('../partials/footer') %>

</body>
</html>
