<article class="idea-card <%= (locals.expanded ? 'expanded' : '') %>" 
         id="idea-<%= idea.idea_id %>" 
         data-id="<%= idea.idea_id %>"
         data-title='<%= (idea.title || '').replace(/'/g, "&#39;") %>'
         data-desc='<%= (idea.description || '').replace(/'/g, "&#39;").replace(/\r?\n/g, "&#10;") %>'
         data-category-id="<%= idea.category_id || '' %>"
         data-tags='<%- JSON.stringify(idea.tags || []).replace(/'/g, "&#39;") %>'
         data-files='<%- JSON.stringify((idea.files || []).map(f => ({ file_id: f.file_id, original_name: f.original_name || f.file_path }))).replace(/'/g, "&#39;") %>'
         data-is-owner="<%= idea.isOwner ? 'true' : 'false' %>"
         data-is-admin="<%= authz.isAdmin(user) ? 'true' : 'false' %>"
         data-user-role="<%= (user && user.role) ? user.role : '' %>"
         data-status="<%= idea.status || '' %>"
         data-user-id="<%= idea.user_id || '' %>"
         data-csrf="<%= (typeof csrfToken !== 'undefined' ? csrfToken : '') %>">


  <header class="idea-header">
    <div>
      <h3 class="idea-title"><%= idea.title || '—' %></h3>
      <div class="idea-meta">
        <% const cat = (categories || []).find(c => String(c.category_id) === String(idea.category_id)); %>
        <span class="idea-category"><%= cat ? cat.name : (idea.category_id || '—') %></span>
        <span class="muted" style="margin-left:0.6rem; font-size:0.85rem;">von <%= idea.author || '—' %></span>
        <% if (String(idea.status || '').toLowerCase() === 'umgesetzt') { %>
          <span class="tag" style="margin-left:0.6rem;">Status: umgesetzt</span>
        <% } %>
        <% if (user && idea.isOwner) { %>
          <span class="tag" style="margin-left:0.6rem;">Status: <%= idea.status || 'neu' %></span>
        <% } %>
      </div>
    </div>
     
      
     <% if (authz.isAdmin(user) && !idea.isOwner && idea.user_id) { %>
        <a class="feedback-link" type="button" href="/dms/direct/<%= idea.user_id %>" title="DM um dem ersteller Feedback zu geben">
          🗣️
        </a>
     <% } %>

    <% if ((user && idea.isOwner) || authz.isAdmin(user)) { %>
      <button class="btn-icon edit-btn" type="button" onclick="openIdeaModal('<%= idea.idea_id %>')" title="Idee bearbeiten">
       ✏️
      </button>
    <% } %>
  </header>

  <p class="idea-desc">
    <% if (idea.description) { %>
      <%= idea.description %>
    <% } else { %>
      Keine Beschreibung
    <% } %>
  </p>

  <div class="idea-tags">
    <% (idea.tags || []).forEach(tag => { %> <span class="tag">#<%= tag %></span> <% }) %>
  </div>

  <% if ((idea.files || []).length) { %>
    <div class="files-preview">
      <h5>Dateien:</h5>
      <div class="files-list">
          <% idea.files.forEach(f => { %>
          <a class="file-link" href="/ideas/files/<%= f.file_id %>/download" target="_blank">📎 <%= f.original_name || f.file_path %></a>
        <% }) %>
      </div>
    </div>
  <% } %>

  <footer class="idea-actions">
    <button
  class="btn outline expand-card"
  type="button"
  aria-expanded="<%= locals.expanded ? 'true' : 'false' %>"
  data-idea-id="<%= idea.idea_id %>"
  hx-get="/ideas/<%= idea.idea_id %>/comments"
  hx-trigger="click once"
  hx-target="#comments-section-<%= idea.idea_id %>"
  hx-swap="outerHTML">
  Kommentare
</button>


    <div hx-get="/ideas/<%= idea.idea_id %>/stats"
         hx-trigger="idea_updated_<%= idea.idea_id %> from:body"
         hx-target="#idea-stats-<%= idea.idea_id %>"
         hx-swap="outerHTML">
      <%- include('_idea-stats', { idea, user }) %>
    </div>
  </footer>

  <div class="idea-expanded">
 
  <div id="comments-section-<%= idea.idea_id %>"></div>

  <form class="comment-form"
        method="POST"
        action="/ideas/<%= idea.idea_id %>/comments"
        hx-post="/ideas/<%= idea.idea_id %>/comments"
        hx-target="#comment-list-<%= idea.idea_id %>"
        hx-swap="afterbegin"
        hx-sync="this:replace"
        hx-on::after-request="this.reset()"
        data-idea-id="<%= idea.idea_id %>">
    <textarea name="text" rows="3" class="input-comment"
              placeholder="Kommentar... (Max. 200 Zeichen)"
              maxlength="200" required></textarea>
    <button class="btn" type="submit">Kommentieren</button>
  </form>
</div>


</article>
