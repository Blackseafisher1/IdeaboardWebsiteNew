<!-- Chat Edit Modal -->
<div id="chatEditModal" class="chat-modal-overlay" style="display: none;">
  <div class="chat-modal-content card">
    <h3>Nachricht bearbeiten</h3>
    <textarea id="chatEditField" class="input-field" rows="4"></textarea>
    <div class="chat-modal-actions">
      <button id="cancelEditBtn" class="btn secondary">Abbrechen</button>
      <button id="saveEditBtn" class="btn primary">Speichern</button>
    </div>
  </div>
</div>

<!-- Chat Message Context Menu -->
<div id="chatContextMenu" class="chat-context-menu" style="display: none;">
  <button id="ctxEditBtn">✎ Bearbeiten</button>
  <button id="ctxDeleteBtn">🗑 Löschen</button>
</div>


