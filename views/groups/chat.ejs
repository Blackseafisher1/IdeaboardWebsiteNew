<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gruppe: <%= group.name %></title>
    <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/dms.css">
    <style>
        .group-layout { display: flex; height: calc(100vh - 120px); gap: 20px; min-width: 0; }
        .chat-main { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; }
        .chat-main .chat-container { width: 100%; min-width: 0; }
        .group-sidebar { flex: 0 0 250px; width: 250px; background: var(--bg-secondary); border-radius: 12px; padding: 15px; display: flex; flex-direction: column; gap: 15px; border: 1px solid var(--border-color); }
        .member-list { flex: 1; overflow-y: auto; list-style: none; padding: 0; margin: 0; }
        .member-item { display: flex; align-items: center; gap: 10px; padding: 8px; border-radius: 6px; }
        .member-item.online .status-dot { background: #4caf50; }
        .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #9e9e9e; }
        .member-role { font-size: 0.75rem; color: var(--text-muted); margin-left: auto; }
        .group-actions { margin-top: auto; padding-top: 15px; border-top: 1px solid var(--border-color); }
        @media (max-width: 1100px) {
            .group-layout { gap: 14px; }
            .group-sidebar { flex-basis: 220px; width: 220px; padding: 12px; }
        }
        @media (max-width: 900px) { .group-sidebar { display: none; } }
    </style>
    <script>
        window.currentUserId = <%= user.id %>;
        window.groupId = <%= group.id %>;
        window.currentConversationId = "<%= currentConversationId %>";
        window.isMember = <%= (typeof isMember !== 'undefined' && isMember) ? 'true' : 'false' %>;
    </script>
</head>
<body class="chat-page">
    <%- include('../partials/header', { activePage: 'chat' }) %>
    
    <main class="container">
        <div class="group-layout">
            <div class="chat-main">
                <div class="chat-container">
                    <div class="chat-header">
                        <button class="back-button" onclick="window.location.href='/projects'">←</button>
                        <div class="user-info">
                            <h2><%= group.name %></h2>
                            <p id="connectionStatus">Offline</p>
                        </div>
                        <div class="mobile-group-menu">
                            <button id="toggleMembersBtn" class="members-toggle-btn">👥</button>
                            <div id="mobileMembersDropdown" class="members-dropdown" style="display: none;">
                                <h4>Mitglieder</h4>
                                <ul class="member-list">
                                    <% members.forEach(member => { %>
                                        <li class="member-item" data-user-id="<%= member.user_id %>">
                                            <div class="status-dot"></div>
                                            <span><%= member.username %></span>
                                            <span class="member-role"><%= member.role %></span>
                                        </li>
                                    <% }) %>
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="chat-messages" 
                         id="messagesContainer"
                         data-last-id="<%= messages.length > 0 ? messages[messages.length - 1].message_id : 0 %>">
                        
                        <% if (messages.length === 20) { %>
                            <div class="load-more-container" 
                                 hx-get="/groups/chat/<%= group.id %>/history?beforeId=<%= messages[0].message_id %>" 
                                 hx-trigger="load-history, click" 
                                 hx-swap="outerHTML">
                                <span class="load-more-text">Ältere Nachrichten laden</span>
                                <div class="loading-spinner" style="display:none">...</div>
                            </div>
                        <% } %>

                        <%- include('../dms/partials/message_items', { messages: messages, currentUserId: (typeof user !== "undefined" && user ? user.id : 0), isGroup: true }) %>
                    </div>
                    
                    <div id="chatUploadPreview" class="chat-upload-preview" hidden></div>

                    <% if (typeof isMember !== 'undefined' && isMember) { %>
                    <div class="chat-input htmx-form-container" id="chatInputBar">
                        <form id="messageForm"
                              hx-post="/groups/send"
                              hx-target="#messagesContainer"
                              hx-swap="beforeend"
                              hx-encoding="multipart/form-data"
                              hx-on::after-request="if(event.detail.successful) { this.querySelector('input[name=message]').value = ''; document.getElementById('chatUploadPreview').innerHTML = ''; document.getElementById('chatUploadPreview').hidden = true; }">
                            
                            <input type="hidden" name="groupId" value="<%= group.id %>">
                            
                            <!-- Hidden File Input for Drag&Drop -->
                            <input type="file" id="chatFileInput" name="file" style="display:none" multiple>
                            
                            <!-- Visible Attachment Button -->
                            <button type="button" id="chatFileButton" class="mini-file-btn" title="Datei anhängen">📎</button>

                            <input type="text" name="message" placeholder="Nachricht an Gruppe..." autocomplete="off">
                            <button type="submit" id="messageSendBtn">Senden</button>
                        </form>
                    </div>
                    <% } else { %>
                    <div class="chat-input" id="chatInputBar">
                        <div class="view-only-note" style="padding:8px 12px; color:var(--text-muted);">Nur Ansicht — Sie sind nicht Mitglied dieser Gruppe. Schreibrechte sind deaktiviert.</div>
                        <div style="display:flex; gap:8px; align-items:center; padding:8px 0;">
                            <input type="text" disabled placeholder="Nur Ansicht — keine Schreibrechte" style="flex:1; padding:8px;" />
                            <button disabled class="btn" style="opacity:0.6;">Senden</button>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="group-sidebar">
                <h3>Mitglieder</h3>
                <ul class="member-list">
                    <% members.forEach(member => { %>
                        <li class="member-item" data-user-id="<%= member.user_id %>">
                            <div class="status-dot"></div>
                            <span><%= member.username %></span>
                            <span class="member-role"><%= member.role %></span>
                        </li>
                    <% }) %>
                </ul>

                <% if (myRole === 'owner' || myRole === 'admin') { %>
                    <div class="add-member">
                        <form action="/groups/<%= group.id %>/members/add" method="POST">
                            <input type="text" name="userId" placeholder="User ID einladen" required style="width:100%; padding:5px; margin-bottom:5px;">
                            <button type="submit" class="btn-small">Hinzufügen</button>
                        </form>
                    </div>
                <% } %>

                <div class="group-actions">
                    <!-- 'Gruppe verlassen' entfernt — Gruppen sind fest mit dem Team verbunden. -->
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/dist/chatClient.min.js"></script>
    <script src="/js/dist/groupLive.min.js"></script>
    <script src="/js/dist/chatDragnDrop.min.js"></script>
</body>
</html>
