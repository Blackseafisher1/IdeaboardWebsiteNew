<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benutzer suchen</title>

    
    <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/dms.css">
</head>
<body class="chat-page dm-search">
    <%- include('../partials/header', { activePage: 'chat' }) %>
    <main class="container chat-page-container">
        <div class="chat-container dm-index-container">
            <div class="back-link">
                <button class="back-button" onclick="window.location.href='/dms'">←</button>
            </div>
            <h1 class="dm-search-title">Benutzer suchen</h1>
            <div class="dms-search">
                <form action="/dms/search" method="get" class="dms-search-form"
                      hx-get="/dms/search" hx-target=".user-list" hx-swap="outerHTML"
                      hx-push-url="true">
                    <div class="search-field">
                      <input type="search" name="q" class="input" placeholder="Benutzername..." 
                             value="<%= searchQuery %>" autocomplete="off"
                             hx-get="/dms/search" hx-target=".user-list" hx-swap="outerHTML"
                            hx-trigger="keyup changed delay:1000ms, search">
                      <span class="search-glass">
                        <svg width="20" height="20" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                          <path d="M28.7,27.29l-9.76-9.56A9,9,0,1,0,12,21a8.92,8.92,0,0,0,5.49-1.89l9.81,9.6a1,1,0,0,0,1.41,0A1,1,0,0,0,28.7,27.29ZM5,12a7,7,0,1,1,7,7A7,7,0,0,1,5,12Z" fill="currentColor"/>
                        </svg>
                      </span>
                      <button type="button" class="clear-search" aria-label="Suche löschen" title="Suche löschen"
                        hx-on:click="const q = document.querySelector('.dms-search-form input[name=\'q\']'); q.value=''; htmx.trigger(q, 'search'); q.focus();">×</button>
                    </div>
                </form>

            </div>

            <div class="user-list-container dm-search-user-list-container">
                <%- include('./partials/user_list', { users: users, allLoaded: (typeof allLoaded !== 'undefined' ? allLoaded : false), searchQuery: searchQuery }) %>
            </div>
            <% if (!allLoaded) { %>
    <div class="user-list-actions">
        <button class="message-btn load-more-btn"
                hx-get="/dms/search?all=1<% if (searchQuery) { %>&q=<%= encodeURIComponent(searchQuery) %><% } %>"
                hx-target=".user-list"
                hx-swap="outerHTML">
            Alle Laden
        </button>
    </div>
<% } %>


    </main>


     <%- include('../partials/footer') %>
</body>
</html>