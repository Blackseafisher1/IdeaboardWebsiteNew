<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Nachrichten - Ideenboard</title>

  
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/dms.css" />
</head>

<body class="chat-page dm-index">
  <%- include('../partials/header', { activePage: 'chat' }) %>

  <main class="container chat-page-container">
    <div class="chat-container dm-index-container">
      <div class="chat-header dm-index-header">
        <h2 class="dmsIndexHeader">Deine Nachrichten</h2>
      </div>

      <div class="dm-panel-content">
        <div class="new-message-container dm-index-new-message">
          <button class="message-btn" onclick="location.href='/dms/search'">
            ➕ Neue Nachricht beginnen
          </button>
        </div>

        <div class="conversation-list dm-index-conversation-list">
          <% if (conversations.length === 0) { %>
            <div class="no-messages">Keine Konversationen gefunden.</div>
          <% } %>

          <% conversations.forEach(conv => { %>
            <div id="conv-last-<%= conv.other_user_id %>" data-conversation-id="<%= conv.conversation_id %>" class="conversation-item" onclick="location.href='/dms/chat/<%= conv.other_user_id %>'">
              <div class="conversation-main">
                <div class="conversation-header">
                  <span class="username"><%= conv.other_username %></span>
                </div>
                <% if (conv.last_message && conv.last_message.startsWith('[FILE]')) { %>
                  <% 
                    let parts = conv.last_message.split('|');
                    let displayName = parts.length > 1 ? parts[1].trim() : 'Datei';
                    if (displayName.length > 80) {
                      displayName = displayName.substring(0, 80) + '...';
                    }
                  %>
                  <div class="last-message-preview">📎 Datei: <%= displayName %></div>
                <% } else { %>
                  <% 
                    let msg = conv.last_message || 'Keine Nachrichten';
                    if (msg.length > 80) {
                      msg = msg.substring(0, 80) + '...';
                    }
                  %>
                  <div class="last-message-preview<%= conv.last_message ? '' : ' empty' %>"><%= msg %></div>
                <% } %>
              </div>
              <div class="conversation-time">
                <%= new Date(conv.updated_at).toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
