<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <link rel="stylesheet" href="/css/style.css">
  
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
   <%- include('../partials/header') %>

<section class="auth-section">
  <div class="auth-card" id="auth-card">
    <!-- Front: Login -->
    <div class="auth-face auth-front">
      <h2 class="auth-title auth-title-right">Login</h2>
      <form action="/users/auth" method="POST">
      <input class="input" type="email" name="email" placeholder="E-Mail" required>
      <input class="input" type="password" name="password" placeholder="Passwort" required>
      <button class="btn primary" type="submit">Anmelden</button>
    </form>
        <% if(!isValid){ %> 
        <div class="validation-error">
            <strong style="color: rgb(235, 0, 0);">Überprüfung fehlgeschlagen!</strong>
            <p style="color: rgb(235, 0, 0);"><%= validationMsg %></p>
        </div>
    <% } %>
      <p>Noch kein Konto? <button type="button" class="auth-toggle" onclick="flipCard()">Registrieren</button></p>
    </div>

    <!-- Back: Register -->
    <div class="auth-face auth-back">
      <h2>Registrieren</h2>
      <form id="registerForm" action="/users/register" method="POST">
          <input class="input" id="reg_username" type="text" name="username" placeholder="Benutzername" required>
          <input class="input" id="reg_email" type="email" name="email" placeholder="E-Mail" required>
          <input class="input" id="reg_password" type="password" name="password" placeholder="Passwort" required>
          <button class="btn primary" type="submit">Registrieren</button>
     </form>
   
      <p>Schon registriert? <button type="button" class="auth-toggle" onclick="flipCard()">Login</button></p>
    </div>
  </div>
</section>

<script src="/js/dist/auth-flip.min.js"></script>
<%- include('../partials/footer') %>

</body>
</html>



