# Caddyfile.local
# Local development Caddyfile (based on Caddyfile.cloudflared).
# Uses Caddy internal CA for TLS so localhost can use Secure cookies in tests.

localhost, 127.0.0.1 {
  encode gzip zstd
  log {
    output stdout
    format json
  }
  tls internal

  # SSE matchers (path-based and Accept header)
  @sse_path {
    path /dms/chat-updates*
  }
  @sse_accept {
    header Accept text/event-stream
  }

  # Prevent intermediaries from transforming SSE
  header @sse_path Cache-Control "no-transform"
  header @sse_accept Cache-Control "no-transform"

  # Proxy SSE requests with immediate flush to keep streaming live
  reverse_proxy @sse_path 127.0.0.1:3000 {
    flush_interval -1
    header_up Host {host}
    header_up X-Real-IP {remote}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote}
  }

  # Also match Accept header if SSE client doesn't use the path
  reverse_proxy @sse_accept 127.0.0.1:3000 {
    flush_interval -1
    header_up Host {host}
    header_up X-Real-IP {remote}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote}
  }

  # All other requests -> app on :3000
  reverse_proxy 127.0.0.1:3000 {
    header_up Host {host}
    header_up X-Real-IP {remote}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote}
  }
}
