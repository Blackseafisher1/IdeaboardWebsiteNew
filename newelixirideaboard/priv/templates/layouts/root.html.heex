<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= assigns[:title] || "Ideenboard" %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <script src="/js/dist/early-theme-blur.min.js" defer></script>
</head>
<body data-user-id="<%= if user = assigns[:user] do %><%= user.user_id %><% end %>">
  <input type="checkbox" id="site-blur-toggle" class="site-blur-toggle" hidden aria-hidden="true">

  <header id="page-header" class="page-header">
    <div class="header-content">
      <div>
        <img src="/assets/logo2.png" alt="logo Ideenboard" class="logo" width="65" height="50" onclick="window.location.href='/'">
      </div>
      <div class="header-right">
        <%= if user = assigns[:user] do %>
          <a href="/users/account" id="Account-Link">👤 <%= user.username %></a>
        <% else %>
          <a href="/users/auth" id="Login-Link">Login</a>
        <% end %>

        <%= if user do %>
          <script>window.currentUserId = <%= user.user_id %>;</script>
        <% end %>

        <button class="theme-toggle" onclick="toggleTheme()">🌙/☀️</button>
        <label for="site-blur-toggle" id="blur-toggle" class="blur-toggle" role="button" tabindex="0" aria-label="Toggle backdrop blur">🔍</label>

        <button class="hamburger" onclick="toggleMenu()" aria-controls="main-nav" aria-expanded="false" aria-label="Menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav id="main-nav" role="navigation" aria-hidden="true" aria-label="Main navigation" tabindex="-1">
          <div class="mobile-nav-header">
            <img src="/assets/logo2.png" alt="logo" class="mobile-nav-logo" onclick="window.location.href='/'">
            <div class="mobile-nav-actions">
              <button class="theme-toggle" onclick="toggleTheme()">🌙/☀️</button>
              <label for="site-blur-toggle" id="blur-toggle-mobile" class="blur-toggle" role="button" tabindex="0" aria-label="Toggle backdrop blur">🔍</label>
              <%= if user do %>
                <a href="/users/account" class="mobile-account-link">👤 <%= user.username %></a>
              <% else %>
                <a href="/users/auth" class="mobile-account-link">Login</a>
              <% end %>
            </div>
          </div>

          <%= if user do %>
            <a href="/ideas" onclick="closeMenu()">Ideen</a>
            <a href="/surveys" onclick="closeMenu()">Umfragen</a>
            <a href="/projects" onclick="closeMenu()">Projekte</a>
            <a href="/dashboard" onclick="closeMenu()">Dashboard</a>
            <a href="/dms" onclick="closeMenu()">Nachrichten</a>
          <% end %>
        </nav>
        <div class="menu-overlay" onclick="closeMenu()"></div>
      </div>
    </div>
  </header>

  <main>
    <%= @inner_content %>
  </main>

  <script src="/js/dist/blur-toggle.min.js" defer></script>
  <%= if user do %>
    <script src="/js/dist/ideasClient.min.js" defer></script>
  <% end %>
</body>
</html>
