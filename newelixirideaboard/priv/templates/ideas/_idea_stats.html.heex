<div class="idea-stats" id="idea-stats-<%= @stats.idea_id %>">
  <button class="btn-like" hx-post="/ideas/<%= @stats.idea_id %>/like" hx-target="#idea-stats-<%= @stats.idea_id %>" hx-swap="outerHTML">
    👍 <%= @stats.like_count || 0 %>
  </button>
  <span>💬 <%= @stats.comment_count || 0 %></span>
</div>
